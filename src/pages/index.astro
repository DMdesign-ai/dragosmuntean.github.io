---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopHUD from '../components/sections/TopHUD.astro';
import BottomStatusBar from '../components/sections/BottomStatusBar.astro';
import LeftPanel from '../components/sections/LeftPanel.astro';
import RightPanel from '../components/sections/RightPanel.astro';
import HeroBlock from '../components/sections/HeroBlock.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import BlogSection from '../components/sections/BlogSection.astro';
import AIBossSection from '../components/sections/AIBossSection.astro';
import RunnerStats from '../components/sections/RunnerStats.astro';
import ResponsiveGameMount from '../components/sections/ResponsiveGameMount';
---

<BaseLayout title="RUNNER_PORTFOLIO.EXE — Dragos Muntean" bodyClass="homepage-lock">
  <div class="md:h-screen md:flex md:flex-col">
    <TopHUD />

    <!-- DESKTOP: 3-column layout (hidden on mobile) -->
    <main class="hidden md:flex flex-1 min-h-0">
      <LeftPanel />

      <div class="flex-1 min-w-0 relative bg-game-bg">
        <ResponsiveGameMount layout="desktop" client:only="react" />
      </div>

      <RightPanel />
    </main>

    <!-- MOBILE: stacked single-column layout (hidden on desktop) -->
    <main class="flex flex-col md:hidden">
      <!-- 1. Hero + Game -->
      <div class="px-4 pt-4 pb-2">
        <HeroBlock mobile />
      </div>
      <div class="w-full aspect-[3/4] max-h-[70vh] relative bg-game-bg">
        <ResponsiveGameMount layout="mobile" client:only="react" />
      </div>

      <!-- 2. Projects -->
      <ProjectsSection />

      <!-- 3. Blog -->
      <BlogSection />

      <!-- 4. AI (under construction) -->
      <AIBossSection />

      <!-- 5. Runner Stats -->
      <RunnerStats />
    </main>

    <BottomStatusBar />
  </div>
</BaseLayout>

<script>
  import gsap from 'gsap';

  // Card entrance animations
  gsap.from('[data-animate="card"]', {
    opacity: 0,
    y: 20,
    stagger: 0.08,
    duration: 0.4,
    ease: 'power2.out',
    delay: 0.3,
  });

  // Score counter animation
  const scoreEl = document.querySelector('[data-score]');
  if (scoreEl) {
    const target = { val: 0 };
    gsap.to(target, {
      val: 99999,
      duration: 2.5,
      ease: 'power1.inOut',
      delay: 0.5,
      onUpdate() {
        scoreEl.textContent = String(Math.floor(target.val)).padStart(5, '0');
      },
    });
  }

  // HUD fade-in
  gsap.from('header', {
    opacity: 0,
    duration: 0.6,
    ease: 'power2.out',
  });

  gsap.from('footer', {
    opacity: 0,
    duration: 0.6,
    ease: 'power2.out',
    delay: 0.2,
  });

</script>
