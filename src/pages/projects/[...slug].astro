---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, company, role, duration, tags, impact, testimonials, image } = project.data;
---

<BaseLayout title={`${title} — Portfolio`} description={description}>
  <div class="min-h-screen bg-game-bg text-terminal-green">
    <!-- Back navigation bar -->
    <header class="h-10 flex items-center border-b border-hud-border px-4 text-xs font-mono">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="text-terminal-dim hover:text-terminal-green transition-colors"
      >
        &lt; BACK TO GAME
      </a>
      <span class="ml-auto font-pixel text-[10px] text-muted-green">{title.toUpperCase()}</span>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-12">
      <!-- Project header block (terminal style) -->
      <div class="bg-card-bg border border-card-border p-6 mb-8">
        <div class="text-muted text-xs mb-2 font-mono">$ cat project.info</div>
        <h1 class="font-pixel text-lg text-terminal-green mb-4">{title}</h1>
        <p class="text-muted-green text-sm mb-4 font-mono">{description}</p>

        <div class="grid grid-cols-2 gap-4 text-xs font-mono">
          {company && (
            <div>
              <span class="text-muted">COMPANY:</span>{' '}
              <span class="text-terminal-green">{company}</span>
            </div>
          )}
          {role && (
            <div>
              <span class="text-muted">ROLE:</span>{' '}
              <span class="text-terminal-green">{role}</span>
            </div>
          )}
          {duration && (
            <div>
              <span class="text-muted">DURATION:</span>{' '}
              <span class="text-terminal-green">{duration}</span>
            </div>
          )}
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag: string) => (
              <span class="text-xs bg-game-bg border border-card-border px-2 py-1 font-mono text-terminal-dim">
                [{tag}]
              </span>
            ))}
          </div>
        )}
      </div>

      <!-- Hero image -->
      {image && (
        <div class="border border-card-border mb-8 overflow-hidden">
          <img
            src={`${import.meta.env.BASE_URL}${image}`}
            alt={`${title} — project screenshot`}
            class="w-full h-auto block"
            loading="eager"
          />
        </div>
      )}

      <!-- Impact metrics -->
      {impact.length > 0 && (
        <div class="bg-card-bg border border-card-border p-6 mb-8">
          <div class="text-muted text-xs mb-3 font-mono">$ cat impact.log</div>
          {impact.map((item: string) => (
            <div class="flex items-start gap-2 mb-2 text-sm font-mono">
              <span class="text-gold shrink-0">+</span>
              <span class="text-terminal-green">{item}</span>
            </div>
          ))}
        </div>
      )}

      <!-- MDX content with terminal prose styling -->
      <div class="prose-terminal font-mono">
        <Content />
      </div>

      <!-- Testimonials -->
      {testimonials.length > 0 && (
        <div class="mt-12">
          <div class="text-muted text-xs mb-4 font-mono">$ cat testimonials.log</div>
          {testimonials.map((t: { quote: string; author: string; role: string }) => (
            <div class="bg-card-bg border-l-2 border-terminal-green p-4 mb-4">
              <p class="text-sm text-muted-green italic font-mono">"{t.quote}"</p>
              <div class="text-xs text-muted mt-2 font-mono">
                -- {t.author}, {t.role}
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- Back to game CTA -->
      <div class="mt-16 text-center">
        <a
          href={`${import.meta.env.BASE_URL}`}
          class="inline-block border border-terminal-green px-6 py-3 text-sm font-pixel hover:bg-terminal-green hover:text-game-bg transition-colors"
        >
          [RETURN TO GAME]
        </a>
      </div>
    </main>
  </div>
</BaseLayout>
