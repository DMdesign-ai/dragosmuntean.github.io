---
import type { BlogArticle } from '../../lib/types';

interface Props {
  article: BlogArticle;
  index: number;
}

const { article, index } = Astro.props;
const postLabel = `POST_0${index + 1}`;
const href = `/blog/${article.slug}`;
---

<a href={href} class="block bg-card-bg border-l-2 border-card-border mb-3 hover:border-terminal-green transition-colors cursor-pointer no-underline overflow-hidden" data-animate="card">
  {article.image && (
    <div class="relative w-full h-28 overflow-hidden border-b border-card-border">
      <img
        src={article.image}
        alt={article.title}
        class="w-full h-full object-cover grayscale brightness-50"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-terminal-green/15 mix-blend-overlay"></div>
      <div class="absolute inset-0 bg-game-bg/30"></div>
    </div>
  )}
  <div class="p-3">
    <div class="flex justify-between items-start">
      <span class="text-xs text-muted">📝 [{postLabel}]</span>
      <span class="text-door-cyan text-[10px]">{article.date}</span>
    </div>
    <h3 class="font-bold text-sm mt-1 text-terminal-green">{article.title}</h3>
    <p class="text-muted text-xs mt-1 leading-relaxed">{article.description}</p>
    <div class="flex flex-wrap gap-1 mt-2">
      {article.tags.map((tag) => (
        <span class="text-[9px] text-terminal-dim border border-card-border px-1.5 py-0.5">{tag}</span>
      ))}
    </div>
  </div>
</a>
