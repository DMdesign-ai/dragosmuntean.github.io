---
import BlinkingCursor from '../ui/BlinkingCursor.astro';
---

<div class="space-y-4">
  <h1 class="font-pixel text-lg text-terminal-green text-glow leading-relaxed">
    RUNNER_<br />PORTFOLIO.EXE
  </h1>
  <p class="text-muted text-xs">// USE [ARROW KEYS] TO EXPLORE</p>

  <!-- Pixel art runner sprite (inline SVG) -->
  <div class="w-8 h-10 relative">
    <svg viewBox="0 0 16 20" width="32" height="40" class="image-rendering-pixelated">
      <!-- Head -->
      <rect x="5" y="0" width="6" height="5" fill="#00ff41" />
      <!-- Eyes -->
      <rect x="6" y="1" width="1" height="1" fill="#0a0e0a" />
      <rect x="9" y="1" width="1" height="1" fill="#0a0e0a" />
      <!-- Body -->
      <rect x="4" y="5" width="8" height="6" fill="#00cc33" />
      <!-- Arms -->
      <rect x="2" y="6" width="2" height="4" fill="#00cc33" />
      <rect x="12" y="6" width="2" height="4" fill="#00cc33" />
      <!-- Legs -->
      <rect x="5" y="11" width="3" height="5" fill="#008822" />
      <rect x="9" y="11" width="3" height="5" fill="#008822" />
      <!-- Shoes -->
      <rect x="4" y="16" width="4" height="2" fill="#ffd700" />
      <rect x="9" y="16" width="4" height="2" fill="#ffd700" />
    </svg>
  </div>

  <p class="text-sm">
    &gt;&gt;&gt; [PRESS START]<BlinkingCursor />
  </p>
</div>
